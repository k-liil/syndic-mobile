{
  "expo": {
    "name": "Syndicly",
    "slug": "syndic-mobile",
    "version": "1.1.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "syndic",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.syndicly.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.syndicly.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "33249219-5a46-45f7-8c6d-5e56412940ce"
      }
    },
    "owner": "lil-k-1"
  }
}
